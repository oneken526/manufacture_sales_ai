# =============================================================
# 本番環境用 .env テンプレート（NFR-030 / TASK-0017）
# =============================================================
# 重要:
#   - APP_KEY は本番環境ごとに新規生成すること: php artisan key:generate
#   - このファイルを .env にコピーし、各値を実際の設定に置き換えること
#   - .env ファイル自体は Git にコミットしないこと（.gitignore に記載済み）
#   - DB 認証情報・APIキー等のシークレットは環境変数またはシークレットマネージャー経由で注入すること
# =============================================================

# ── アプリケーション基本設定 ──────────────────────────
APP_NAME="製造業販売管理システム"
APP_ENV=production
# 必ず php artisan key:generate で本番環境専用キーを生成すること
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── ログ設定 ──────────────────────────────────────────
# 本番環境では warning 以上のみ記録（DEBUG情報の漏洩防止）
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── データベース設定（MySQL / PostgreSQL） ────────────
# NFR-030: 本番環境では MySQL または PostgreSQL を使用すること
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=manufacture_sales
DB_USERNAME=manufacture_user
# シークレット管理機構（環境変数 or シークレットマネージャー）経由で注入すること
DB_PASSWORD=

# PostgreSQL を使用する場合は以下のコメントを外して上記を削除:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=manufacture_sales
# DB_USERNAME=manufacture_user
# DB_PASSWORD=

# ── セッション・キャッシュ設定 ────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=your-domain.example.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── メール設定 ───────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.your-mail-provider.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user
# シークレット管理機構経由で注入すること
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@your-domain.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI連携設定（Phase 2 / REQ-100〜104） ─────────────
# Phase 2 実装時に設定すること。空の場合 AI 連携機能は無効。
# シークレット管理機構経由で注入すること
ANTHROPIC_API_KEY=
ANTHROPIC_API_MODEL=claude-sonnet-4-6

# ── フロントエンド ────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
